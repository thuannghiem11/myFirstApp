<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1118">

<!--    bottom navigator-->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bottom_navigation_color"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentBottom="true">

        <ImageView
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_weight="1"
        android:src="@drawable/ic_user_navigation"
        android:contentDescription="@string/user_icon" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:src="@drawable/ic_nagivation_checkbox"
            android:contentDescription="@string/checkbox_icon" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:src="@drawable/ic_navigation_add_circle"
            android:contentDescription="@string/add_medicine_icon"/>
    </LinearLayout>

<!--    scroll view-->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:background="@color/dark_background"

        >


        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp" >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                >
                <LinearLayout
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/morning_section"
                    android:padding = "16dp"
                    >
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text = "@string/medicine_name"
                      /><TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text = "@string/medical_reminder" />
                </LinearLayout>

                <CheckBox
                    android:layout_width="32dp"
                    android:layout_height="32dp"></CheckBox>



            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>